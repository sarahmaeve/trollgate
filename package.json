{
  "name": "trollgate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:apply:local": "wrangler d1 execute trollgate --local --file ./schema.sql",
    "db:seed:local": "wrangler d1 execute trollgate --local --file ./seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@types/node": "^22.19.19",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6",
    "wrangler": "^4.0.0"
  }
}
