# Copy to .dev.vars (gitignored) for local `wrangler dev`.
# Register a GitHub OAuth App: https://github.com/settings/developers
#   Authorization callback URL: http://localhost:8787/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub numeric ids allowed to create/manage events (comma-separated).
# Empty = nobody (fail closed). Find yours: https://api.github.com/users/<login>
ADMIN_GITHUB_IDS=

# Display brand (sidebar + page title). Blank → "Trollgate".
BRAND_NAME=

# Phase 5 (cancellation email)
RESEND_API_KEY=

# Phase 6 (Stripe)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
